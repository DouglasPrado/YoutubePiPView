{
  "name": "ytview-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:desktop": "turbo dev --filter=@ytview/desktop",
    "dev:extension": "turbo dev --filter=@ytview/chrome-extension",
    "build:desktop": "turbo build --filter=@ytview/desktop",
    "build:extension": "turbo build --filter=@ytview/chrome-extension",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
